{
  "id": "conversationhudv14",
  "title": "ConversationHUD v14",
  "description": "<p>A simple module that adds a nice HUD that display the portraits of all the characters present in a conversation. Foundry VTT v14 compatible fork of CristianVasile23/conversation-hud.</p>",
  "version": "14.0.0",
  "compatibility": {
    "minimum": "14",
    "verified": "14",
    "maximum": "14"
  },
  "authors": [
    {
      "name": "Saervicus (Cristian Vasile)",
      "discord": "Saervicus#7305",
      "url": "https://github.com/CristianVasile23",
      "flags": {}
    }
  ],
  "relationships": {
    "requires": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "compatibility": {
          "minimum": "1.12.4.0",
          "verified": "1.12.13.1"
        }
      },
      {
        "id": "socketlib",
        "type": "module",
        "compatibility": {
          "minimum": "1.0.10",
          "verified": "1.0.13"
        }
      },
      {
        "id": "lib-dfreds-ui-extender",
        "type": "module",
        "compatibility": {}
      }
    ]
  },
  "esmodules": ["js/init.js"],
  "styles": [
    {
      "src": "css/main.css"
    },
    {
      "src": "font/font.css"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    },
    {
      "lang": "fr",
      "name": "Français",
      "path": "lang/fr.json",
      "flags": {}
    }
  ],
  "socket": true,
  "url": "https://github.com/AxiumDND/conversationhudv14",
  "manifest": "https://github.com/AxiumDND/conversationhudv14/releases/latest/download/module.json",
  "download": "https://github.com/AxiumDND/conversationhudv14/releases/download/14.0.0/module.zip",
  "license": "LICENSE",
  "readme": "README.md",
  "media": [
    {
      "type": "setup",
      "url": "https://raw.githubusercontent.com/CristianVasile23/conversation-hud/main/docs/icons/setup.jpg",
      "loop": false,
      "flags": {}
    },
    {
      "type": "cover",
      "url": "https://raw.githubusercontent.com/CristianVasile23/conversation-hud/main/docs/icons/cover.jpg",
      "loop": false,
      "flags": {}
    }
  ],
  "packs": [
    {
      "name": "chud-macro-compendium",
      "label": "ConversationHUD v14 Macros",
      "path": "packs/chud-macro-compendium",
      "type": "Macro",
      "ownership": {
        "PLAYER": "NONE",
        "TRUSTED": "OBSERVER",
        "ASSISTANT": "OWNER"
      },
      "system": "dnd5e"
    }
  ]
}
